# Copy to .env and fill in real values. Do not commit .env.
#
# Transport (first set wins): BREVO_API_KEY, then RESEND_API_KEY, then Gmail
# SMTP. Use an HTTP API in production — Render's free tier blocks outbound SMTP.

# --- Option A: Brevo HTTP API (recommended: many recipients, no domain) ---
# brevo.com > verify a sender > SMTP & API > API Keys (starts with xkeysib-).
# EMAIL_FROM must be your verified Brevo sender address.
BREVO_API_KEY=
# EMAIL_FROM=pgopalakrishnan1996@gmail.com

# --- Option B: Resend HTTP API (only your own address without a domain) ---
# Get a key at resend.com > API Keys (starts with re_).
RESEND_API_KEY=
# From address. onboarding@resend.dev works with no domain setup (Resend then
# only delivers to your own Resend account email).
# EMAIL_FROM=onboarding@resend.dev

# --- Option B: Gmail SMTP (local fallback) ---
# Gmail with 2-Step Verification requires a 16-char App Password (not the
# normal account password): Google Account > Security > App passwords.
SENDER_EMAIL=your-sender@gmail.com
SENDER_PASSWORD=your-app-password

# Comma-separated recipient list for the "Send Email" button.
EMAIL_IDS=recipient1@example.com,recipient2@example.com

# Port the email server listens on (optional).
EMAIL_SERVER_PORT=3001
